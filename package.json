{
  "name": "myu-mbti",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:get-song-image": "tsc -p get_song_image/tsconfig.json",
    "get-song-image": "npm run build:get-song-image && node get_song_image/dist/main.js",
    "build:get-songs-preview-url": "tsc -p get_songs_previewUrl/tsconfig.json",
    "get-songs-preview-url": "npm run build:get-songs-preview-url && node get_songs_previewUrl/dist/main.js",
    "test:get-song-image": "vitest run --config get_song_image/vitest.config.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.1"
  }
}
